server.port=8088
spring.application.name=APIGateway

eureka.client.serviceUrl.defaultZone=http://eureka:8761/eureka

spring.cloud.gateway.server.webflux.routes[0].id=cart
spring.cloud.gateway.server.webflux.routes[0].uri=lb://CART
spring.cloud.gateway.server.webflux.routes[0].predicates[0]=Path=/carts/**

spring.cloud.gateway.server.webflux.routes[1].id=product-catalogue
spring.cloud.gateway.server.webflux.routes[1].uri=lb://PRODUCTCATALOGUE
spring.cloud.gateway.server.webflux.routes[1].predicates[0]=Path=/catalogue/**

spring.cloud.gateway.server.webflux.routes[2].id=product
spring.cloud.gateway.server.webflux.routes[2].uri=lb://PRODUCT
spring.cloud.gateway.server.webflux.routes[2].predicates[0]=Path=/productdetails/**

spring.cloud.gateway.server.webflux.routes[3].id=pricing
spring.cloud.gateway.server.webflux.routes[3].uri=lb://PRICING
spring.cloud.gateway.server.webflux.routes[3].predicates[0]=Path=/price/**

spring.cloud.gateway.server.webflux.routes[4].id=inventory
spring.cloud.gateway.server.webflux.routes[4].uri=lb://INVENTORY
spring.cloud.gateway.server.webflux.routes[4].predicates[0]=Path=/inventory/**

spring.cloud.gateway.server.webflux.routes[5].id=recommendation
spring.cloud.gateway.server.webflux.routes[5].uri=lb://RECOMMENDATION
spring.cloud.gateway.server.webflux.routes[5].predicates[0]=Path=/recommendations/**

